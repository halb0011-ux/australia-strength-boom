{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Main motivations for participation in sport and physical activity.",
  "width": 650,
  "height": 330,
  "data": {
    "url": "data_clean/fitness_motivations.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "Motivation",
      "type": "nominal",
      "sort": "-x",
      "title": "Motivation"
    },
    "x": {
      "field": "Percentage",
      "type": "quantitative",
      "title": "Participation rate (%)"
    },
    "color": {
      "field": "Percentage",
      "type": "quantitative",
      "scale": {
        "scheme": "tealblues"
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "Motivation",
        "type": "nominal"
      },
      {
        "field": "Percentage",
        "type": "quantitative",
        "title": "Percentage (%)"
      }
    ]
  }
}