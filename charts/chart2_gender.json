{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Fitness/Gym participation by gender among Australian adults.",
  "width": 500,
  "height": 320,
  "data": {
    "url": "data_clean/fitness_gender.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "x": {
      "field": "Gender",
      "type": "nominal",
      "title": "Gender"
    },
    "y": {
      "field": "Participation",
      "type": "quantitative",
      "title": "Participation rate (%)"
    },
    "color": {
      "field": "Gender",
      "type": "nominal",
      "scale": {
        "range": ["#2563eb", "#16a34a"]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "Gender",
        "type": "nominal"
      },
      {
        "field": "Participation",
        "type": "quantitative",
        "title": "Participation (%)"
      }
    ]
  }
}