{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Trend in adults meeting the muscle-strengthening guideline by sex.",
  "title": {
    "text": "Adults Meeting Muscle-Strengthening Guidelines",
    "subtitle": "Percentage of adults aged 18–64 meeting the guideline, AIHW 2016–2018",
    "anchor": "middle",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "fontWeight": "bold",
    "offset": 15
  },
  "width": 900,
  "height": 420,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data_clean/muscle_strengthening_trend.csv"
  },
  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "sort": [2016, 2017, 2018],
      "title": "Year"
    },
    "y": {
      "field": "percentage",
      "type": "quantitative",
      "title": "Adults meeting guideline (%)",
      "scale": {
        "domain": [25, 50]
      }
    },
    "color": {
      "field": "sex",
      "type": "nominal",
      "scale": {
        "domain": ["Male", "Female"],
        "range": ["#2563eb", "#16a34a"]
      },
      "title": "Sex"
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "sex",
        "type": "nominal",
        "title": "Sex"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Percentage (%)"
      }
    ]
  }
}