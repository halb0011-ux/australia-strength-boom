{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Donut chart showing Australian powerlifting records by sex from 2010 to 2025.",
  "title": {
    "text": "Australian Powerlifting Records by Gender",
    "subtitle": "Share of recorded entries, 2010–2025",
    "anchor": "middle",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "fontWeight": "bold",
    "offset": 15
  },
  "width": 900,
  "height": 460,
  "data": {
    "url": "data_clean/powerlifting_gender.csv"
  },
  "transform": [
    {
      "calculate": "datum.sex == 'M' ? 'Male' : datum.sex == 'F' ? 'Female' : 'Mx'",
      "as": "sex_label"
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "lifters",
          "as": "total_lifters"
        }
      ]
    },
    {
      "calculate": "datum.lifters / datum.total_lifters * 100",
      "as": "share"
    },
    {
      "calculate": "datum.sex_label + ': ' + format(datum.share, '.1f') + '%'",
      "as": "label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 95,
        "outerRadius": 175,
        "stroke": "white",
        "strokeWidth": 2
      },
      "encoding": {
        "theta": {
          "field": "lifters",
          "type": "quantitative"
        },
        "color": {
          "field": "sex_label",
          "type": "nominal",
          "scale": {
            "domain": ["Male", "Female", "Mx"],
            "range": ["#2563eb", "#16a34a", "#94a3b8"]
          },
          "title": "Sex"
        },
        "tooltip": [
          {
            "field": "sex_label",
            "type": "nominal",
            "title": "Sex"
          },
          {
            "field": "lifters",
            "type": "quantitative",
            "title": "Records"
          },
          {
            "field": "share",
            "type": "quantitative",
            "title": "Share (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 205,
        "fontSize": 12,
        "fontWeight": "bold"
      },
      "encoding": {
        "theta": {
          "field": "lifters",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        },
        "color": {
          "field": "sex_label",
          "type": "nominal",
          "scale": {
            "domain": ["Male", "Female", "Mx"],
            "range": ["#2563eb", "#16a34a", "#64748b"]
          },
          "legend": null
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "text": "2010–2025"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 18,
        "fontWeight": "bold",
        "color": "#111827"
      },
      "encoding": {
        "text": {
          "field": "text"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}